# /etc/nginx/sites-available/nhl-picks
# Пример reverse-proxy конфига для nginx на хосте.
# HTTPS-сертификат проще всего получить через certbot:
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d picks.example.com
# certbot сам допишет блок с listen 443 ssl.

server {
    listen 80;
    server_name picks.example.com;

    # Большие формы пиков — ставим лимит чуть выше дефолтного.
    client_max_body_size 1m;

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_read_timeout 60s;
    }
}
