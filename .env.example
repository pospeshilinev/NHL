# --- Postgres ---
POSTGRES_USER=nhl
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=nhl
# Внутри docker-compose host = "postgres". Локально без docker = "localhost"
DATABASE_URL=postgres://nhl:change-me-strong@postgres:5432/nhl

# --- Auth.js ---
# openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-bytes
AUTH_URL=http://10.185.22.36:3000
AUTH_TRUST_HOST=true

# --- Bootstrap первого админа ---
# При первом старте приложение создаст этого пользователя с ролью admin,
# если такого ещё нет. После создания переменные можно очистить.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-too

# --- Cron ---
CRON_SECRET=long-random-string

# --- Сезон NHL для NHL API ---
# например 20252026
NHL_SEASON=20252026
