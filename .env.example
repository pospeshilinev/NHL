# --- Postgres ---
POSTGRES_USER=nhl
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=nhl
# Внутри docker-compose host = "postgres". Локально без docker = "localhost"
DATABASE_URL=postgres://nhl:change-me-strong@postgres:5432/nhl

# --- Auth.js ---
# openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-bytes
AUTH_URL=https://your-domain.example
AUTH_TRUST_HOST=true

# --- SMTP для magic link (Microsoft Exchange) ---
# Типовые значения для on-prem Exchange:
#   PORT=587, SECURE=false  (STARTTLS — самый частый кейс)
# Для legacy:
#   PORT=25,  SECURE=false
# Для SMTPS:
#   PORT=465, SECURE=true
EMAIL_SERVER_HOST=mail.your-company.local
EMAIL_SERVER_PORT=587
EMAIL_SERVER_SECURE=false
EMAIL_SERVER_USER=nhl-picks@your-company.com
EMAIL_SERVER_PASSWORD=mailbox-password
EMAIL_FROM="NHL Picks <nhl-picks@your-company.com>"

# --- Cron ---
CRON_SECRET=long-random-string

# --- Сезон NHL для NHL API ---
# например 20242025
NHL_SEASON=20242025
